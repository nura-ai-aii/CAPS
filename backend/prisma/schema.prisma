datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Order {
  id              String   @id @default(uuid())
  orderNumber     String   @unique
  status          String   @default("Waiting") // Waiting, Ready to Print, Printing, Printed, Failed
  customerDetails String?
  
  // Settings as a JSON string to keep it simple, or separate fields
  paperSize       String
  colorMode       String
  copies          Int
  instructions    String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  files           File[]
}

model File {
  id           String @id @default(uuid())
  originalName String
  mimeType     String
  size         Int
  path         String // Local path where file is stored
  
  orderId      String
  order        Order  @relation(fields: [orderId], references: [id])
}
